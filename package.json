{
  "name": "jiangtian-official-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run compress:public-images",
    "compress:public-images": "node scripts/compress-public-images.mjs",
